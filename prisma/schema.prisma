generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id        Int      @id @default(autoincrement())
  text      String
  completed Boolean  @default(false)
  date      String?
  priority  String   @default("baixa")
  createdAt DateTime @default(now())
}